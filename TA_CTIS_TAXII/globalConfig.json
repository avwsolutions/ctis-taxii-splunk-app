{
    "pages": {
        "configuration": {
            "tabs": [
                {
                    "name": "taxii_config",
                    "restHandlerModule": "taxii_config_validator",
                    "restHandlerClass": "CustomConnectionValidator",
                    "table": {
                        "actions": [
                            "edit",
                            "delete",
                            "clone"
                        ],
                        "header": [
                            {
                                "label": "Name",
                                "field": "name"
                            },
                            {
                                "label": "API Root URL",
                                "field": "api_root_url"
                            }
                        ]
                    },
                    "entity": [
                        {
                            "type": "text",
                            "label": "Name",
                            "validators": [
                                {
                                    "type": "regex",
                                    "errorMsg": "Config Name must begin with a letter and consist exclusively of alphanumeric characters and underscores.",
                                    "pattern": "^[a-zA-Z]\\w*$"
                                },
                                {
                                    "type": "string",
                                    "errorMsg": "Length of name should be between 1 and 100",
                                    "minLength": 1,
                                    "maxLength": 100
                                }
                            ],
                            "field": "name",
                            "help": "A unique name for the config.",
                            "required": true
                        },
                        {
                            "type": "text",
                            "label": "TAXII API Root URL",
                            "field": "api_root_url",
                            "help": "Example: https://taxii2.example.org/trustgroup1/",
                            "required": true
                        },
                        {
                            "type": "singleSelect",
                            "label": "Authentication Type",
                            "field": "auth_type",
                            "help": "Authentication type to connect to the TAXII server.",
                            "required": true,
                            "options": {
                                "autoCompleteFields": [
                                    {
                                        "label": "Basic",
                                        "value": "basic"
                                    },
                                    {
                                        "label": "API Key / Bearer Token",
                                        "value": "custom"
                                    }
                                ]
                            },
                            "modifyFieldsOnValue": [
                                {
                                    "fieldValue": "basic",
                                    "fieldsToModify": [
                                        {
                                            "fieldId": "username",
                                            "required": true,
                                            "display": true
                                        },
                                        {
                                            "fieldId": "password",
                                            "required": true,
                                            "display": true
                                        },
                                        {
                                            "fieldId": "http_header_name",
                                            "required": false,
                                            "display": false
                                        },
                                        {
                                            "fieldId": "http_header_value",
                                            "required": false,
                                            "display": false
                                        }
                                    ]
                                },
                                {
                                    "fieldValue": "custom",
                                    "fieldsToModify": [
                                        {
                                            "fieldId": "username",
                                            "required": false,
                                            "display": false
                                        },
                                        {
                                            "fieldId": "password",
                                            "required": false,
                                            "display": false
                                        },
                                        {
                                            "fieldId": "http_header_name",
                                            "required": true,
                                            "display": true
                                        },
                                        {
                                            "fieldId": "http_header_value",
                                            "required": true,
                                            "display": true
                                        }
                                    ]
                                }
                            ]
                        },
                        {
                            "type": "text",
                            "label": "Username",
                            "field": "username",
                            "help": "Username",
                            "options": {
                                "display": false
                            }
                        },
                        {
                            "type": "text",
                            "label": "Password",
                            "field": "password",
                            "help": "Password",
                            "encrypted": true,
                            "options": {
                                "display": false
                            }
                        },
                        {
                            "type": "text",
                            "label": "HTTP Header Name",
                            "field": "http_header_name",
                            "help": "The HTTP Header to set HTTP Header Value as.",
                            "defaultValue": "Authorization",
                            "options": {
                                "display": false
                            }
                        },
                        {
                            "type": "text",
                            "label": "HTTP Header Value",
                            "field": "http_header_value",
                            "help": "Example: 'Bearer <token>' or your API Key Value",
                            "encrypted": true,
                            "options": {
                                "display": false
                            }
                        }
                    ],
                    "title": "TAXII Configurations"
                },
                {
                    "type": "loggingTab"
                }
            ],
            "title": "Configuration",
            "description": "Add TAXII v2.1 connection configurations.",
            "subDescription": {
                "text": "For more information see the [[docsLink]].",
                "links": [
                    {
                        "slug": "docsLink",
                        "link": "https://splunk.github.io/ctis-taxii-splunk-app",
                        "linkText": "Documentation"
                    }
                ]
            }
        },
        "inputs": {
            "services": [],
            "title": "Inputs",
            "description": "Manage your data inputs",
            "table": {
                "actions": [
                    "edit",
                    "delete",
                    "clone"
                ],
                "header": [
                    {
                        "label": "Name",
                        "field": "name"
                    },
                    {
                        "label": "Interval",
                        "field": "interval"
                    },
                    {
                        "label": "Index",
                        "field": "index"
                    },
                    {
                        "label": "Status",
                        "field": "disabled"
                    }
                ],
                "moreInfo": [
                    {
                        "label": "Name",
                        "field": "name"
                    },
                    {
                        "label": "Interval",
                        "field": "interval"
                    },
                    {
                        "label": "Index",
                        "field": "index"
                    },
                    {
                        "label": "Status",
                        "field": "disabled",
                        "mapping": {
                            "true": "Disabled",
                            "false": "Enabled"
                        }
                    }
                ]
            }
        },
        "dashboard": {
            "panels": [
                {
                    "name": "default"
                }
            ]
        }
    },
    "meta": {
        "name": "TA_CTIS_TAXII",
        "restRoot": "TA_CTIS_TAXII",
        "version": "1.17.0+b2cc40b",
        "displayName": "CTIS TAXII App",
        "schemaVersion": "0.0.9",
        "supportedThemes": [
            "dark",
            "light"
        ]
    }
}
